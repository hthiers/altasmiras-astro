---
import Button from '@components/ui/Button.astro';
import { Image } from 'astro:assets';

interface HeroContent {
    title: string;
    description: string;
    buttons?: {
        text: string;
        link: string;
        variant?: 'primary' | 'secondary' | 'ghostLight' | 'ghostDark';
        target?: string;
    }[];
    backgroundImage?: string | any;
    overlayOpacity?: number;
    newsTicker?: { title: string; slug: string; excerpt?: string }[];
}

interface Props {
    content: HeroContent;
}

const { content } = Astro.props;
const opacity = content.overlayOpacity ?? 1; // Default opacity if not specified
---

<section class="header-offset relative">
    {content.backgroundImage && (
        <div class="absolute inset-0 left-0 top-0 w-full h-full overflow-hidden">
            <Image
                src={content.backgroundImage}
                alt=""
                width={1920}
                height={1080}
                class="w-full h-full object-cover"
                quality={70}
                format="webp"
                loading="eager"
                decoding="async"
            />
            <div
                class="hero-background absolute inset-0 left-0 top-0 w-full h-full overflow-hidden"
                style={`opacity: ${opacity};`}
            ></div>
        </div>
    )}

    <div class="site-container mx-auto px-4 py-large relative z-10 flex flex-col md:items-center md:justify-center md:text-center">
        <h1 class="text-white text-balance" data-aos="fade-up">{content.title}</h1>
        <p class="text-white mt-2 text-balance" data-aos="fade-up" data-aos-delay="100">{content.description}</p>
        {content.buttons && content.buttons.length > 0 && (
            <div class="flex flex-wrap gap-4 mt-8" data-aos="fade-up">
                {content.buttons.map((button) => (
                    <Button
                        href={button.link}
                        target={button.target || '_self'}
                        variant={button.variant || 'primary'}
                    >
                        {button.text}
                    </Button>
                ))}
            </div>
        )}
    </div>

    {content.newsTicker && content.newsTicker.length > 0 && (
        <div
            id="news-ticker"
            class="absolute bottom-0 left-0 right-0 z-10 flex items-stretch overflow-hidden"
            style="background: var(--color-secondary-dark);"
            data-news-items={JSON.stringify(content.newsTicker)}
        >
            <span
                class="hidden sm:flex items-center shrink-0 px-4 text-xs font-bold uppercase tracking-widest border-r border-white/20"
                style="color: var(--color-primary); background: var(--color-secondary);"
            >
                Noticias
            </span>
            <a
                id="ticker-link"
                href={`/blog/${content.newsTicker[0].slug}`}
                class="ticker-link flex items-center px-4 py-3 overflow-hidden flex-1 gap-4 group/ticker"
            >
                <div class="flex flex-col justify-center overflow-hidden flex-1">
                    <span id="ticker-title" class="text-sm font-semibold text-white truncate group-hover/ticker:text-white/70 transition-colors duration-200">
                        {content.newsTicker[0].title}
                    </span>
                    <span id="ticker-excerpt" class="text-xs text-white/70 truncate mt-0.5">
                        {content.newsTicker[0].excerpt ?? ''}
                    </span>
                </div>
                <span class="hidden sm:block text-white/40 shrink-0 group-hover/ticker:text-white/70 transition-colors duration-200" aria-hidden="true">→</span>
            </a>
        </div>
    )}
</section>

<style>
    .ticker-link {
        transition: opacity 0.3s ease;
    }
</style>

<script>
    const ticker = document.getElementById('news-ticker');
    if (ticker) {
        const raw = ticker.dataset.newsItems;
        const items: { title: string; slug: string; excerpt?: string }[] = raw ? JSON.parse(raw) : [];
        const linkEl = document.getElementById('ticker-link') as HTMLAnchorElement | null;
        const titleEl = document.getElementById('ticker-title');
        const excerptEl = document.getElementById('ticker-excerpt');

        if (linkEl && titleEl && items.length > 1 && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            let current = 0;
            setInterval(() => {
                linkEl.style.opacity = '0';
                setTimeout(() => {
                    current = (current + 1) % items.length;
                    titleEl.textContent = items[current].title;
                    linkEl.href = `/blog/${items[current].slug}`;
                    if (excerptEl) excerptEl.textContent = items[current].excerpt ?? '';
                    linkEl.style.opacity = '1';
                }, 300);
            }, 4000);
        }
    }
</script>
