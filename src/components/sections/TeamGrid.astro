---
import { getCollection } from 'astro:content';
import { getPaddingClass } from '@utils/styleUtils';
import type { PaddingSize } from '@utils/styleUtils';

interface Props {
    padding?: PaddingSize;
    paddingTop?: PaddingSize;
    paddingBottom?: PaddingSize;
}

const { padding, paddingTop, paddingBottom } = Astro.props;
const paddingClass = getPaddingClass({ padding, paddingTop, paddingBottom });

const teamMembers = await getCollection('team', ({ data }) => {
    return data.publish !== false;
});

const sortedTeamMembers = teamMembers.sort((a, b) => a.data.order - b.data.order);

const hasEmails = sortedTeamMembers.some((m) => m.data.email);
---

<section class:list={['relative', paddingClass]}>
    <div class="site-container mx-auto px-4">
        <div class="overflow-x-auto">
            <table style="width: 100%; border-collapse: collapse; font-size: var(--text-small);">
                <thead>
                    <tr>
                        <th
                            style="background-color: var(--color-secondary); color: #ffffff; font-weight: 600; text-align: left; padding: 0.75rem 1rem; border: 1px solid var(--color-secondary-light);"
                        >
                            Nombre
                        </th>
                        <th
                            style="background-color: var(--color-secondary); color: #ffffff; font-weight: 600; text-align: left; padding: 0.75rem 1rem; border: 1px solid var(--color-secondary-light);"
                        >
                            Cargo
                        </th>
                        {
                            hasEmails && (
                                <th
                                    style="background-color: var(--color-secondary); color: #ffffff; font-weight: 600; text-align: left; padding: 0.75rem 1rem; border: 1px solid var(--color-secondary-light);"
                                >
                                    Correo
                                </th>
                            )
                        }
                    </tr>
                </thead>
                <tbody>
                    {
                        sortedTeamMembers.map((member, index) => (
                            <tr style={index % 2 === 0 ? 'background-color: #ffffff;' : 'background-color: #e8edf5;'}>
                                <td
                                    style="padding: 0.75rem 1rem; border: 1px solid #d1d5db; color: var(--color-headline); vertical-align: middle;"
                                >
                                    {member.data.name}
                                </td>
                                <td
                                    style="padding: 0.75rem 1rem; border: 1px solid #d1d5db; color: var(--color-headline); vertical-align: middle;"
                                >
                                    {member.data.jobTitle}
                                </td>
                                {hasEmails && (
                                    <td
                                        style="padding: 0.75rem 1rem; border: 1px solid #d1d5db; vertical-align: middle;"
                                    >
                                        {member.data.email ? (
                                            <a
                                                href={`mailto:${member.data.email}`}
                                                style="color: var(--color-primary);"
                                            >
                                                {member.data.email}
                                            </a>
                                        ) : (
                                            '—'
                                        )}
                                    </td>
                                )}
                            </tr>
                        ))
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
