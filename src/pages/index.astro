---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/sections/Hero.astro';
import SplitPanel from '@components/sections/SplitPanel.astro';
import Features from '@components/sections/Features.astro';
import Stats from '@components/sections/Stats.astro';
import { featureLists } from '@data/features';
import { statsLists } from '@data/stats';
import Faqs from '@components/sections/Faqs.astro';
import { faqLists } from '@data/faqs';
import heroImage from '../assets/images/home/hero-altasmiras.jpg';
import aboutImage from '../assets/images/home/about.jpg';

const seoTitle = 'Fundación Altasmiras — Capacitación y Desarrollo';
const seoDescription =
    'Institución sin fines de lucro que promueve la capacitación y el desarrollo de personas en sectores rurales y vulnerables de La Araucanía y Los Ríos.';

const heroContent = {
    title: 'Capacitando personas, transformando comunidades',
    description:
        'Fundación Altasmiras promueve el desarrollo de personas en sectores rurales y vulnerables, con un enfoque técnico, social y humano basado en valores de respeto, dignidad y compromiso.',
    buttons: [
        { text: 'Conoce nuestros cursos', link: '/cursos', target: '_self' },
        { text: 'Contáctanos', link: '/contact', target: '_self' },
    ],
    backgroundImage: heroImage,
    overlayOpacity: 0.4,
};

const featuresSection = {
    eyebrow: 'CURSOS 2025',
    title: 'Áreas de Capacitación',
    description:
        'Durante 2025 ejecutamos cursos de oficio en las regiones de Los Ríos y La Araucanía, fortaleciendo habilidades prácticas y promoviendo el desarrollo laboral.',
    features: featureLists.main.features,
    button: { text: 'Ver Cursos 2025', link: '/cursos', variant: 'primary' as const },
};

const quienesSomosSection = {
    eyebrow: 'QUIÉNES SOMOS',
    headline: 'Una fundación comprometida con las personas',
    description:
        'Somos una institución sin fines de lucro creada en 2017 por la Diócesis de Villarrica. Promovemos la capacitación y el desarrollo de personas en sectores rurales y vulnerables, con un enfoque técnico, social y humano basado en valores de respeto, dignidad y compromiso.',
    image: { src: aboutImage, alt: 'Fundación Altasmiras' },
    buttons: [{ text: 'Nuestra Historia', link: '/nosotros', variant: 'primary' as const }],
};

const impactoStats = {
    eyebrow: 'NUESTRO IMPACTO',
    title: 'Impacto real en las comunidades',
    description:
        'Desde 2017 hemos capacitado a cientos de personas en la Región de La Araucanía y Los Ríos, generando oportunidades de empleo y emprendimiento.',
    variant: 'default' as const,
    stats: statsLists.main.stats,
};

const compromisoCtaBanner = {
    eyebrow: 'NUESTRO COMPROMISO',
    title: 'La capacitación como herramienta de transformación social',
    description:
        'Creemos que la capacitación es una herramienta real de transformación social. Nuestro compromiso es seguir generando oportunidades que impacten positivamente la vida de las personas y sus comunidades.',
    hideCta: false,
    button: { text: 'Contáctanos', link: '/contact', target: '_self' },
};

const faqsSection = {
    eyebrow: 'PREGUNTAS FRECUENTES',
    title: 'Preguntas Frecuentes',
    description: 'Encuentra respuestas a las preguntas más comunes sobre nuestra fundación y nuestros cursos.',
    faqs: faqLists.main.faqs,
};
---

<Layout footerCta={compromisoCtaBanner} title={seoTitle} description={seoDescription}>
    <Hero content={heroContent} />
    <Features content={featuresSection} padding="base" background="light" />
    <SplitPanel content={quienesSomosSection} imagePosition="right" background="base" padding="base" />
    <Stats content={impactoStats} background="dark" padding="base" />
    <Faqs content={faqsSection} background="base" padding="base" />
</Layout>
