---
import Layout from '@layouts/Layout.astro';
import InnerHero from '@components/sections/InnerHero.astro';
import TeamGrid from '@components/sections/TeamGrid.astro';

const seoTitle = "Nuestro Equipo | Fundación Altasmiras";
const seoDescription = "Conoce al equipo de personas comprometidas con el desarrollo de competencias para el futuro.";

const heroContent = {
    title: "Nuestro Equipo",
    description: "Conoce a las personas detrás de Fundación Altasmiras",
}

---

<Layout title={seoTitle} description={seoDescription}>
    <InnerHero content={heroContent}  />
    <TeamGrid padding="base" />
</Layout>