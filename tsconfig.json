{
	"extends": "astro/tsconfigs/strict",
	"include": [
		".astro/types.d.ts",
		"**/*",
		"./worker-configuration.d.ts"
	],
	"exclude": [
		"dist"
	],
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"@components/*": [
				"./src/components/*"
			],
			"@layouts/*": [
				"./src/layouts/*"
			],
			"@styles/*": [
				"./src/styles/*"
			],
			"@images/*": [
				"./src/images/*"
			],
			"@data/*": [
				"./src/data/*"
			],
			"@utils/*": [
				"./src/utils/*"
			],
			"@assets/*": [
				"./src/assets/*"
			]
		}
	}
}